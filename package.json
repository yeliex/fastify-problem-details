{
  "name": "@yeliex/fastify-problem-details",
  "description": "Problem Details for HTTP APIs (RFC 9457) implementation for fastify (or pure nodejs)\n",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test:type": "tsc --build",
