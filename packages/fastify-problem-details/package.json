{
  "name": "@yeliex/fastify-problem-details",
  "version": "1.3.0",
  "description": "Problem Details for HTTP APIs (RFC 9457) implementation for fastify",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pkgroll --clean --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "problem",
    "problem-details",
    "fastify",
    "fastify-plugin",
    "rfc9457",
    "rfc7807"
  ],
  "author": "yeliex <yeliex@yeliex.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeliex/fastify-problem-details",
    "directory": "packages/fastify-problem-details"
  },
  "homepage": "https://github.com/yeliex/fastify-problem-details",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@yeliex/problem-details": "workspace:^",
    "accepts": "^1.3.8",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@types/accepts": "^1.3.7",
    "fastify": "^5.7.4"
  },
  "peerDependencies": {
    "fastify": "^5.7.4"
  }
}
