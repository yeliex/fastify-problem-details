{
  "name": "@yeliex/problem-details",
  "version": "1.4.0",
  "description": "Problem Details for HTTP APIs (RFC 9457) core implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pkgroll --clean",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./http-error": {
      "require": "./dist/http-error.cjs",
      "import": "./dist/http-error.js",
      "types": "./dist/http-error.d.ts"
    }
  },
  "keywords": [
    "problem",
    "problem-details",
    "rfc9457",
    "rfc7807"
  ],
  "author": "yeliex <yeliex@yeliex.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeliex/fastify-problem-details",
    "directory": "packages/problem-details"
  },
  "homepage": "https://github.com/yeliex/fastify-problem-details",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
